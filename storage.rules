rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper Functions ───────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function hasRole(role) {
      return request.auth.token.role == role;
    }

    // ─── Blood Reports ──────────────────────────────────────
    // Upload: only the patient (owner) can upload to their folder.
    // Read:   owner, doctors, hospitals, or superadmins can read.
    match /blood_reports/{uid}/{fileName} {
      allow write: if isAuthenticated() && isOwner(uid);
      allow read: if isAuthenticated() && (
        isOwner(uid) ||
        hasRole('doctor') ||
        hasRole('hospital') ||
        hasRole('superadmin')
      );
    }

    // ─── Default Deny ───────────────────────────────────────
    // Everything not matched above is fully denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
